# VHS recording: ccpool setup walkthrough (shim-backed, no real OAuth)
# Run from repo root: vhs docs/captures/setup.tape
# Output: docs/img/setup.gif
Output docs/img/setup.gif
Set FontSize 14
Set Width 1100
Set Height 700
Set Padding 18
Set Theme "Catppuccin Mocha"
Set TypingSpeed 30ms

Env PATH "docs/captures/_demo-env:/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin"

Hide
Type "clear"
Enter
Show

Type "ccpool setup"
Sleep 200ms
Enter
Sleep 8000ms
