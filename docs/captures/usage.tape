# VHS recording: ccpool usage table
# Run from repo root: vhs docs/captures/usage.tape
# Output: docs/img/usage.gif
Output docs/img/usage.gif
Set FontSize 14
Set Width 1100
Set Height 360
Set Padding 18
Set Theme "Catppuccin Mocha"
Set TypingSpeed 30ms

Env PATH "docs/captures/_demo-env:/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin"

Hide
Type "clear"
Enter
Show

Type "ccpool usage"
Sleep 200ms
Enter
Sleep 2500ms
