# Maintainer: cmaxctl contributors <noreply@cmaxctl.dev>
# Submitted to AUR after first stable release. Until then, use the
# `pipx install cmaxctl` path or build from source via `makepkg -si`
# in this directory.

pkgname=cmaxctl
pkgver=1.0.0
pkgrel=1
pkgdesc="Smart Claude Max account rotation. Zero daemons. Zero lock-in."
arch=('any')
url="https://github.com/torkay/cmaxctl"
license=('MIT')
depends=(
  'python>=3.11'
  'libsecret'  # secret-tool CLI for keyring backend
  'bash'
)
optdepends=(
  'caam: required at runtime for account isolation'
  'claude-code: required at runtime for inference'
  'gnome-keyring: libsecret backend host'
)
makedepends=(
  'python-build'
  'python-installer'
  'python-setuptools'
)
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/torkay/cmaxctl/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')  # set on first release

build() {
  cd "${pkgname}-${pkgver}"
  python -m build --wheel --no-isolation
}

package() {
  cd "${pkgname}-${pkgver}"
  python -m installer --destdir="${pkgdir}" dist/*.whl
  install -Dm755 bin/cmax "${pkgdir}/usr/bin/cmax"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
